# AgentPhone (https://agentphone.ai)
AGENT_PHONE_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
AGENT_PHONE_AGENT_ID=agt_xxxxxxxxxxxxxxxxxxxx
AGENT_PHONE_NUMBER_ID=num_xxxxxxxxxxxxxxxxxxxx
# Optional: webhook signing secret returned when you POST /v1/webhooks.
# Leave empty for dev — signature verification is skipped when unset.
AGENT_PHONE_WEBHOOK_SECRET=

# OpenAI (orchestrator LLM)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Browser Use (Sonnet 4.6 via their hosted model proxy)
BROWSER_USE_API_KEY=bu_xxxxxxxxxxxxxxxxxxxx

# Optional: override the orchestrator model
# ORCHESTRATOR_MODEL=gpt-5.4-nano-2026-03-17

# Voice (RFC-3) — set after running scripts/provision_voice_agent.py
VOICE_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxx
# KID_VERIFICATION_TIMEOUT_SECONDS=45
# BROWSER_USE_FETCH_TIMEOUT_SECONDS=90
# VOICE_NARRATION_INTERVAL_SECONDS=4.5
